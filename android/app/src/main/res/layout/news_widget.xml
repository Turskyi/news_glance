<!--suppress AndroidDomInspection -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_container"
    style="@style/Widget.Android.AppWidget.Container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:theme="@style/Theme.Android.AppWidgetContainer">

    <!-- Signal Icon -->
    <TextView
        android:id="@+id/signal_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:gravity="center"
        android:text="✅"
        android:textSize="28sp"
        tools:targetApi="p" />

    <!-- Signal Label (e.g., "ALL CLEAR") -->
    <TextView
        android:id="@+id/headline_title"
        style="@style/Widget.Android.AppWidget.InnerView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="8dp"
        android:layout_toEndOf="@+id/signal_icon"
        android:ellipsize="end"
        android:gravity="start|center_vertical"
        android:maxLines="1"
        android:fontFamily="casual"
        android:textFontWeight="700"
        android:text="ALL CLEAR"
        android:textStyle="bold"
        android:textColor="#047857"
        android:textSize="14sp"
        tools:targetApi="p" />

    <!-- Conclusion Text -->
    <TextView
        android:id="@+id/headline_description"
        style="@style/Widget.Android.AppWidget.InnerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/signal_icon"
        android:layout_alignParentStart="true"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="5"
        android:text="No insight available"
        android:textColor="#047857"
        android:textSize="14sp" />

    <!-- Category and Probability metadata -->
    <TextView
        android:id="@+id/signal_metadata"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/headline_description"
        android:layout_alignParentStart="true"
        android:layout_marginTop="6dp"
        android:alpha="0.7"
        android:text="TRAVEL • 85% Probability"
        android:textColor="#047857"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Branding footer with timestamp -->
    <TextView
        android:id="@+id/widget_timestamp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/signal_metadata"
        android:layout_alignParentStart="true"
        android:layout_marginTop="6dp"
        android:alpha="0.5"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="News Glance from now"
        android:textColor="#047857"
        android:textSize="9sp" />

</RelativeLayout>
